POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=lemipay

## ON DEVELOPMENT USE:
## DATABASE_URL=postgres://mateo:mateo@localhost:5432/lemipay
# FOR DOCKER USE:
DATABASE_URL=postgres://mateo:mateo@db:5432/lemipay

PORT_SERVER=3000
PORT_CLIENT=5173

## Frontend → backend base URL (SvelteKit PUBLIC_*, no secrets)
## Prefer this root .env; client/.env is only a fallback.
PUBLIC_API_URL=http://localhost:3000

JWT_SECRET=cabezazo al teclado
MAIL_SERVER_SECRET=cabezazo al teclado
MAIL_API_URL=http://localhost:5173

## REOWN PROJECT ID
REOWN_KEY=ir a reown crear un projecto y copiar la key

## ALCHEMY URL
ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/tu_api_key_aca

VAULT_ADDRESS=contract address
PRIVATE_KEY=signer key

## Gemini API KEY
GEMINI_API_KEY=key

## Investment price oracle (CoinGecko only)
# mock = random walk offline
# live = precios reales desde CoinGecko
PRICE_ORACLE_MODE=mock

# Mapa por sección (coins|stocks|commodities) → link en/{tag}/{id}:
#   server/config/coingecko_tickers.toml
#   ej. [stocks] NVDA = "nvidia" → https://www.coingecko.com/en/stocks/nvidia
# COINGECKO_TICKERS_FILE=/ruta/a/coingecko_tickers.toml
#
# Estrategias + proporciones (synced a DB al arrancar):
#   server/config/investment_strategies.toml
# INVESTMENT_STRATEGIES_FILE=/ruta/a/investment_strategies.toml
#
# API key opcional (Demo/Pro) si te rate-limitean:
# COINGECKO_API_KEY=tu_key
# COINGECKO_KEY_TYPE=demo
